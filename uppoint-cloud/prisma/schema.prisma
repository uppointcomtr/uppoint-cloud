generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TenantRole {
  OWNER
  ADMIN
  MEMBER
}

enum NotificationChannel {
  EMAIL
  SMS
}

enum NotificationOutboxStatus {
  PENDING
  SENT
  FAILED
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  phone         String?   @unique
  emailVerified DateTime?
  phoneVerifiedAt DateTime?
  image         String?
  passwordHash         String
  tokenVersion         Int       @default(0)
  failedLoginAttempts  Int       @default(0)
  lockedUntil          DateTime?
  lastLoginAt          DateTime?
  deletedAt            DateTime?
  accounts      Account[]
  sessions      Session[]
  passwordResetTokens PasswordResetToken[]
  passwordResetChallenges PasswordResetChallenge[]
  loginChallenges LoginChallenge[]
  registrationVerificationChallenges RegistrationVerificationChallenge[]
  tenantMemberships TenantMembership[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([deletedAt])
}

model Tenant {
  id          String    @id @default(cuid())
  slug        String    @unique
  name        String
  deletedAt   DateTime?
  members     TenantMembership[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model TenantMembership {
  id        String     @id @default(cuid())
  tenantId  String
  userId    String
  role      TenantRole @default(MEMBER)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([userId, role])
  @@index([tenantId, role])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([userId, expiresAt])
}

model PasswordResetChallenge {
  id                 String    @id @default(cuid())
  userId             String
  emailCodeHash      String
  emailCodeVerifiedAt DateTime?
  emailCodeExpiresAt DateTime
  emailCodeAttempts  Int       @default(0)
  smsCodeHash        String?
  smsCodeVerifiedAt  DateTime?
  smsCodeExpiresAt   DateTime?
  smsCodeAttempts    Int       @default(0)
  resetTokenHash     String?
  resetTokenExpiresAt DateTime?
  resetTokenUsedAt   DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([emailCodeExpiresAt])
  @@index([smsCodeExpiresAt])
  @@index([resetTokenExpiresAt])
}

// Tracks auth request attempts per IP for rate limiting.
// Uses an append-only pattern; old rows are cleaned up probabilistically.
model RateLimitAttempt {
  id        String   @id @default(cuid())
  key       String   // "<action>:<ip>" e.g. "register:1.2.3.4"
  createdAt DateTime @default(now())

  @@index([key, createdAt])
}

// Records security-relevant events for forensic analysis.
model AuditLog {
  id        String   @id @default(cuid())
  action    String   // e.g. "login_success", "otp_failed", "password_reset"
  ip        String?
  userId    String?
  actorId   String?
  targetId  String?
  tenantId  String?
  result    String?
  reason    String?
  requestId String?
  userAgent String?
  forwardedFor String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@index([requestId])
  @@index([result, createdAt])
  @@index([tenantId, createdAt])
  @@index([createdAt])
}

model LoginChallenge {
  id                  String    @id @default(cuid())
  userId              String
  mode                String
  codeHash            String
  codeExpiresAt       DateTime
  codeAttempts        Int       @default(0)
  verifiedAt          DateTime?
  loginTokenHash      String?
  loginTokenExpiresAt DateTime?
  loginTokenUsedAt    DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, mode])       // deleteChallengesForUserAndMode(userId, mode)
  @@index([loginTokenHash])     // consumeLoginToken → findChallengeByTokenHash
  @@index([codeExpiresAt])      // cleanup: süresi dolmuş challenge'lar
  @@index([loginTokenExpiresAt]) // cleanup: süresi dolmuş tokenlar
}

model RevokedSessionToken {
  id        String   @id @default(cuid())
  jti       String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
}

model RegistrationVerificationChallenge {
  id                 String    @id @default(cuid())
  userId             String?
  email              String
  name               String
  phone              String
  passwordHash       String
  emailCodeHash      String
  emailCodeExpiresAt DateTime
  emailCodeAttempts  Int       @default(0)
  emailCodeVerifiedAt DateTime?
  smsCodeHash        String?
  smsCodeExpiresAt   DateTime?
  smsCodeAttempts    Int       @default(0)
  smsCodeVerifiedAt  DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([email])
  @@index([emailCodeExpiresAt])
  @@index([smsCodeExpiresAt])
}

model IdempotencyRecord {
  id          String   @id @default(cuid())
  action      String
  key         String
  subjectHash String   @default("global")
  statusCode  Int
  contentType String?
  body        String
  createdAt   DateTime @default(now())
  expiresAt   DateTime

  @@unique([action, key, subjectHash])
  @@index([action, subjectHash])
  @@index([expiresAt])
}

model NotificationOutbox {
  id           String                  @id @default(cuid())
  channel      NotificationChannel
  tenantId     String?
  userId       String?
  recipient    String
  subject      String?
  body         String
  status       NotificationOutboxStatus @default(PENDING)
  attemptCount Int                     @default(0)
  maxAttempts  Int                     @default(5)
  nextAttemptAt DateTime               @default(now())
  lockedAt     DateTime?
  lockedBy     String?
  sentAt       DateTime?
  lastError    String?
  metadata     Json?
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @default(now()) @updatedAt

  @@index([status, nextAttemptAt])
  @@index([createdAt])
  @@index([sentAt])
  @@index([tenantId, status, nextAttemptAt])
  @@index([userId, status, nextAttemptAt])
}
