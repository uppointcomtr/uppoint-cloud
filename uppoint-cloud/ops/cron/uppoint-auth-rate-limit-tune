# Uppoint Cloud auth rate-limit tune (every 30 min)
# Report + safe apply mode (only if enough sample is available)
SHELL=/bin/bash
PATH=/usr/bin:/bin

# Runs as root because nginx access log and config drift checks are root-scoped.
*/30 * * * * root /usr/bin/env -i PATH=/usr/bin:/bin /usr/bin/flock -n /var/lock/uppoint-auth-rate-limit-tune.lock /opt/uppoint-cloud/scripts/tune-auth-rate-limit.sh --tail-lines 30000 --min-sample 300 >> /var/log/uppoint-auth-rate-limit-tune.log 2>&1
