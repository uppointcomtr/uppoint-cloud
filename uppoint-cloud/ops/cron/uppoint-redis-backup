# Uppoint Cloud Redis backup (daily)
SHELL=/bin/bash
PATH=/usr/bin:/bin

# Runs as root because Redis backup destination and retention cleanup are root-owned.
40 2 * * * root /usr/bin/env -i PATH=/usr/bin:/bin /usr/bin/flock -n /var/lock/uppoint-redis-backup.lock /opt/uppoint-cloud/scripts/backup-redis.sh >> /var/log/uppoint-redis-backup.log 2>&1
