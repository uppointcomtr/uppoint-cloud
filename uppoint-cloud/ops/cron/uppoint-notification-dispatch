# Uppoint Cloud notification outbox dispatcher (every minute)
SHELL=/bin/bash
PATH=/usr/bin:/bin

# Runs dispatcher as www-data (least privilege) while keeping root-owned lock and log destination.
* * * * * root /usr/bin/env -i PATH=/usr/bin:/bin /usr/bin/flock -n /var/lock/uppoint-notification-dispatch.lock /usr/sbin/runuser -u www-data -- /opt/uppoint-cloud/scripts/dispatch-notifications.sh >> /var/log/uppoint-cloud/dispatch-notifications.log 2>&1
