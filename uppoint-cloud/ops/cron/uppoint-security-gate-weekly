# Uppoint Cloud full security gate verification (weekly)
SHELL=/bin/bash
PATH=/usr/bin:/bin

# Runs full local security gate (lint/typecheck/tests/build + security checks).
# Remote auth smoke is enforced in read-only mode by default for this weekly CI/ops check.
# Weekly schedule keeps runtime validation active even without code changes.
30 5 * * 0 root /usr/bin/env -i PATH=/usr/bin:/bin SECURITY_GATE_REQUIRE_REMOTE_SMOKE=1 E2E_ALLOW_MUTATIONS=0 E2E_BASE_URL=https://cloud.uppoint.com.tr /usr/bin/flock -n /var/lock/uppoint-security-gate-weekly.lock /opt/uppoint-cloud/scripts/verify-security-gate.sh >> /var/log/uppoint-security-gate-weekly.log 2>&1
