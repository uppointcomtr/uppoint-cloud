{
  "name": "uppoint-cloud",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:deploy": "next build && npm run service:restart",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "test": "vitest run",
    "test:e2e": "bash ./scripts/run-e2e-smoke-local.sh",
    "test:e2e:remote": "RUN_E2E=1 vitest run tests/e2e --testTimeout=30000",
    "verify": "npm run lint && npm run typecheck && npm run test && npm run test:e2e && npm run build",
    "verify:nginx-drift": "bash ./scripts/check-nginx-config-drift.sh",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:migrate:status": "prisma migrate status",
    "service:restart": "if [ \"${NEXT_SKIP_SERVICE_RESTART:-0}\" = \"1\" ]; then echo \"Skipping service restart (NEXT_SKIP_SERVICE_RESTART=1)\"; elif command -v systemctl >/dev/null 2>&1 && systemctl cat uppoint-cloud.service >/dev/null 2>&1; then systemctl restart uppoint-cloud.service && systemctl is-active --quiet uppoint-cloud.service && echo \"uppoint-cloud.service restarted\"; else echo \"Skipping service restart (systemd or uppoint-cloud.service unavailable)\"; fi"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/client": "^6.19.2",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.36.3",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.575.0",
    "next": "16.1.6",
    "next-auth": "^4.24.13",
    "nodemailer": "^7.0.13",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.2",
    "redis": "^5.11.0",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "prisma": "^6.19.2",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
